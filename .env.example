# App
SECRET_KEY=local-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=postgresql+asyncpg://loglens:loglens@postgres:5432/loglens

# Redis (not used in V0 — reserved for V1 Celery)
REDIS_URL=redis://redis:6379/0

# OpenRouter (used for distillation + letter generation)
OPENROUTER_API_KEY=your-key-here
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# Whisper (local model for voice transcription)
WHISPER_MODEL=base

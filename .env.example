# App
SECRET_KEY=local-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=postgresql+asyncpg://loglens:loglens@postgres:5432/loglens

# Redis (not used in V0 — reserved for V1 Celery)
REDIS_URL=redis://redis:6379/0

# Anthropic (not used in V0 stubs — swap in when key arrives)
ANTHROPIC_API_KEY=your-key-here

# Whisper (not used in V0 — reserved for V1 voice)
WHISPER_MODEL=base
